---
interface Props {
  icon: string;
  title: string;
  description: string;
  motion?: 'slide-in-left' | 'slide-in-right' | 'zoom-in';
  motionDuration?: string;
}

const {
  icon,
  title,
  description,
  motion = 'slide-in-left',
  motionDuration = '700ms',
} = Astro.props;
---

<and-card and-motion={motion} and-motion-trigger="enter" and-motion-duration={motionDuration}>
  <and-card-header>
    <div and-layout="horizontal align:center gap:xs">
      <and-icon name={icon} size="18" class="text-primary"></and-icon>
      <and-card-title>{title}</and-card-title>
    </div>
    <and-card-description>{description}</and-card-description>
  </and-card-header>
  <and-card-content>
    <slot />
  </and-card-content>
</and-card>
