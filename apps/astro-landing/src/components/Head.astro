---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<meta charset="UTF-8" />
<meta name="description" content="Andersseen — A powerful, framework-agnostic web component ecosystem" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

<!-- Blocking head scripts (must run before first paint) -->
<script is:inline src="/scripts/enable-animations.js"></script>
<script is:inline src="/scripts/theme-restore.js"></script>
<script is:inline src="/scripts/clear-hash.js"></script>
