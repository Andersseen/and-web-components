---
interface Props {
  icon: string;
  title: string;
  description: string;
  delay?: string;
}

const { icon, title, description, delay = '0ms' } = Astro.props;
---

<and-card
  class="h-full"
  and-motion="slide-in-up"
  and-motion-trigger="enter"
  and-motion-delay={delay}
>
  <and-card-header>
    <div class="h-12 w-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
      <and-icon name={icon} size="24"></and-icon>
    </div>
    <and-card-title>{title}</and-card-title>
  </and-card-header>
  <and-card-content>
    <p and-text="p-sm" class="text-muted-foreground">
      <slot>{description}</slot>
    </p>
  </and-card-content>
</and-card>
