---
import SectionHeader from '../components/SectionHeader.astro';
import PackageCard from '../components/PackageCard.astro';
import { links, packageGroups, packages, packagesByGroup } from '../lib/site-data';

const installCommand = 'npm install @andersseen/web-components @andersseen/layout @andersseen/motion @andersseen/icon';
---

<section id="ecosystem">
  <div and-layout="vertical gap:xxl p-y:xxxl p-x:lg" class="max-w-[1200px] mx-auto">
    <SectionHeader
      badge="Ecosystem"
      title="Modular By Design"
      description={`${packages.length} packages, no cross-dependencies between the core six. Every version below is read from the workspace at build time, so this list cannot drift from what is actually released.`}
    />

    {/* The section groups itself with the library's own tabs — the page is
        the demo. */}
    <and-tabs default-value="core" and-motion="fade" and-motion-trigger="enter">
      <and-tabs-list>
        {packageGroups.map(group => <and-tabs-trigger value={group.id}>{group.label}</and-tabs-trigger>)}
      </and-tabs-list>

      {
        packageGroups.map(group => (
          <and-tabs-content value={group.id}>
            <div and-layout="vertical gap:lg p-y:md">
              <p and-text="p-sm" class="text-muted-foreground max-w-[640px]">
                {group.blurb}
              </p>
              <div and-layout="grid cols:1 cols@md:2 gap:lg" class="items-stretch">
                {packagesByGroup(group.id).map((pkg, index) => (
                  <PackageCard
                    icon={pkg.icon}
                    name={pkg.name}
                    subtitle={pkg.subtitle}
                    description={pkg.description}
                    version={pkg.version}
                    tags={pkg.tags}
                    delay={`${index * 60}ms`}
                  />
                ))}
              </div>
            </div>
          </and-tabs-content>
        ))
      }
    </and-tabs>

    <!-- CTA Final -->
    <div
      and-layout="vertical align:center gap:lg p:xxl"
      class="accent-panel"
      and-motion="zoom"
      and-motion-trigger="enter"
      and-motion-duration="800ms"
    >
      <div class="h-16 w-16 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
        <and-icon name="zap" size="32"></and-icon>
      </div>
      <h3 and-text="h3 align:center weight:bold" class="tracking-tight">Ready to Build?</h3>
      <p and-text="p align:center" class="text-muted-foreground max-w-[500px]">
        Start with the four packages driving this page — everything else is additive, and nothing locks you in.
      </p>
      <div and-layout="horizontal gap:md align:center wrap:wrap justify:center">
        <and-button size="lg" href={links.docs}>
          <and-icon name="download" size="18"></and-icon>
          Get started
        </and-button>
        <and-button variant="outline" size="lg" href={links.github} target="_blank">
          <and-icon name="github" size="18"></and-icon>
          View on GitHub
        </and-button>
      </div>
      <code class="code-surface block w-full max-w-[720px] px-4 py-3 text-sm text-center break-all">
        {installCommand}
      </code>
    </div>
  </div>
</section>
