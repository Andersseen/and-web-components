---
import SectionHeader from '../components/SectionHeader.astro';
import FeatureCard from '../components/FeatureCard.astro';
import { links } from '../lib/site-data';

const tools = [
  {
    icon: 'terminal',
    title: 'MCP Server',
    description:
      'Run npx -y @andersseen/mcp and your assistant queries the live component catalog — generated from the real custom-elements manifest — for correct, framework-specific code.',
    tags: ['Claude', 'Cursor', 'VS Code'],
    delay: '0ms',
  },
  {
    icon: 'book-open',
    title: 'Agent Skills',
    description:
      'Installable, per-library skills for Claude Code, Cursor and other agents. Teach your assistant one package at a time — only the ones your project actually uses.',
    tags: ['@andersseen/skills'],
    delay: '80ms',
  },
  {
    icon: 'file-text',
    title: 'System Prompts',
    description:
      'Curated context blocks to paste into any assistant that does not speak MCP — drops hallucinated props, selectors and class names to near zero.',
    tags: ['Zero-config', 'Any LLM'],
    delay: '160ms',
  },
];

const mcpConfig = `// .mcp.json (Claude) — or .vscode/mcp.json / .cursor/mcp.json
{
  "mcpServers": {
    "and-web-components": {
      "command": "npx",
      "args": ["-y", "@andersseen/mcp"]
    }
  }
}`;
---

<section id="ai-tools" class="bg-muted/30 border-y">
  <div and-layout="vertical gap:xxl p-y:xxxl p-x:lg" class="max-w-[1200px] mx-auto">
    <SectionHeader
      badge="AI Tools"
      title="Built for AI-Native Development"
      description="However your team codes with AI, this ecosystem meets it there — a live MCP server, installable agent skills, and copy-paste context so assistants generate real components instead of plausible ones."
    />

    <div and-layout="grid cols:1 cols@md:3 gap:lg" class="items-stretch">
      {
        tools.map(tool => (
          <FeatureCard
            icon={tool.icon}
            title={tool.title}
            description={tool.description}
            tags={tool.tags}
            delay={tool.delay}
          />
        ))
      }
    </div>

    <!-- MCP quick start -->
    <div
      and-layout="vertical gap:lg p:xxl"
      class="accent-panel"
      and-motion="zoom"
      and-motion-trigger="enter"
      and-motion-duration="800ms"
    >
      <div and-layout="horizontal align:center gap:md wrap:wrap">
        <div class="h-14 w-14 shrink-0 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
          <and-icon name="terminal" size="28"></and-icon>
        </div>
        <div and-layout="vertical gap:xxs">
          <h3 and-text="h3 weight:bold" class="tracking-tight">Connect the MCP server</h3>
          <p and-text="p" class="text-muted-foreground max-w-[560px]">
            No install — it runs on demand. Add it to your assistant, then ask it to build with And Web Components.
          </p>
        </div>
      </div>

      <code class="code-surface block px-4 py-3 text-sm whitespace-pre-wrap break-all text-foreground/90"
        >npx -y @andersseen/mcp</code
      >

      <code
        class="code-surface block px-4 py-3 text-xs sm:text-sm whitespace-pre overflow-x-auto text-foreground/85"
        >{mcpConfig}</code
      >

      <div and-layout="horizontal gap:md align:center wrap:wrap">
        <and-button variant="outline" size="lg" href={`${links.github}/tree/main/packages/mcp`} target="_blank">
          <and-icon name="github" size="18"></and-icon>
          Read the docs
        </and-button>
      </div>
    </div>
  </div>
</section>
