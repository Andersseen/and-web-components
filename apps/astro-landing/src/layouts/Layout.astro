---
interface Props {
  title: string;
}

const { title } = Astro.props;

// NOTE: `@andersseen/web-components/style.css` is intentionally NOT imported
// here — global.css pulls it in through `@import ... layer(andersseen)` so it
// lands in a cascade layer. See the comment at the top of global.css.
import "../styles/global.css";
import "@andersseen/motion/style.css";
import "@andersseen/layout/dist/layout.css";

import Head from "../components/Head.astro";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <Head title={title} />
  </head>
  <body class="bg-background text-foreground antialiased min-h-screen font-sans">
    <slot />
    <script>
      import "../scripts/init";
    </script>
  </body>
</html>
