{
  "name": "@andersseen/mcp-server",
  "version": "0.1.0",
  "description": "MCP Server for @andersseen libraries - Headless components, Web Components, Icons, Motion & Layout",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "web-components",
    "headless-ui",
    "anthropic",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Andersseen/and-web-components.git",
    "directory": "packages/mcp-server"
  }
}
