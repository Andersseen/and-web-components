{
  "name": "@andersseen/icon",
  "version": "0.0.3",
  "description": "Shared icon library for Andersseen web components",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "dist-cjs",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist dist-cjs && tsc && tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist dist-cjs",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "icons",
    "svg",
    "web-components"
  ],
  "author": "Andersseen",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^10.1.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Andersseen/and-web-components.git",
    "directory": "packages/icon-library"
  }
}
