{
  "name": "@andersseen/vanilla-components",
  "version": "0.0.2",
  "description": "EXPERIMENTAL — proof-of-concept zero-dependency vanilla custom elements. Not production-ready; use @andersseen/web-components instead.",
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "dist-cjs",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist dist-cjs && tsc && node ../../scripts/fix-esm-extensions.cjs dist && tsc -p tsconfig.cjs.json && cp src/style.css dist/style.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "test -d dist || pnpm run build"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "vanilla",
    "typescript",
    "framework-agnostic",
    "zero-dependencies"
  ],
  "author": "Andersseen",
  "license": "MIT",
  "dependencies": {},
  "peerDependencies": {
    "@andersseen/headless-components": ">=0.3.0",
    "@andersseen/motion": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "@andersseen/motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@andersseen/headless-components": "workspace:*",
    "@andersseen/motion": "workspace:*",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Andersseen/and-web-components.git",
    "directory": "packages/vanilla-components"
  }
}
