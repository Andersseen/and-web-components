{
  "name": "@andersseen/web-components",
  "version": "0.4.0",
  "description": "Accessible, framework-agnostic web components built with Stencil",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/web-components/web-components.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./lazy": {
      "import": "./dist/web-components/web-components.esm.js"
    },
    "./components": {
      "types": "./dist/types/components.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*.js": "./dist/components/*.js",
    "./components/*": "./dist/components/*.js",
    "./dist/components": {
      "types": "./dist/types/components.d.ts",
      "default": "./dist/components/index.js"
    },
    "./dist/components/*.js": "./dist/components/*.js",
    "./dist/components/*": "./dist/components/*.js",
    "./components/all": "./dist/components/all.js",
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs.js"
    },
    "./style.css": "./dist/web-components/web-components.css",
    "./dist/web-components/web-components.css": "./dist/web-components/web-components.css",
    "./tokens.css": "./themes/tokens.css",
    "./elements.css": "./dist/web-components/elements.css",
    "./tailwind-preset": "./tailwind-preset.js",
    "./colors/*.css": "./themes/colors/*.css",
    "./colors/*": "./themes/colors/*.css",
    "./themes": "./themes/index.css",
    "./themes/*": "./themes/*",
    "./themes/colors": "./themes/colors/index.css",
    "./themes/styles": "./themes/styles/index.css",
    "./themes/colors/*": "./themes/colors/*",
    "./themes/styles/*": "./themes/styles/*",
    "./indigo-rose": "./themes/indigo-rose.css",
    "./slate-amber": "./themes/slate-amber.css",
    "./emerald-orange": "./themes/emerald-orange.css",
    "./violet-cyan": "./themes/violet-cyan.css",
    "./rose-teal": "./themes/rose-teal.css",
    "./default": "./themes/default.css",
    "./compact": "./themes/compact.css",
    "./playful": "./themes/playful.css",
    "./retro": "./themes/retro.css",
    "./elegant": "./themes/elegant.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Andersseen/and-web-components.git",
    "directory": "packages/web-components"
  },
  "author": "Andersseen",
  "sideEffects": [
    "*.css",
    "./dist/web-components/web-components.css",
    "./dist/components/*.js",
    "./dist/define-all-custom-elements.js"
  ],
  "files": [
    "dist/",
    "loader/",
    "themes/",
    "tailwind-preset.js"
  ],
  "scripts": {
    "build": "stencil build && node scripts/generate-all-barrel.cjs && node scripts/build-elements-css.mjs",
    "start": "stencil build --dev --watch --serve",
    "test": "node scripts/ensure-built.cjs && vitest run",
    "test:spec": "vitest run --project spec",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "generate": "stencil generate",
    "prepublishOnly": "pnpm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "pnpm run build && storybook build"
  },
  "devDependencies": {
    "@stencil-community/postcss": "^2.2.0",
    "@stencil/angular-output-target": "^1.4.0",
    "@stencil/core": "^4.43.3",
    "@stencil/react-output-target": "^1.6.0",
    "@stencil/vitest": "^1.12.1",
    "@stencil/vue-output-target": "^0.14.0",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/web-components": "^10.2.16",
    "@storybook/web-components-vite": "^10.2.16",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.1.0",
    "lit": "^3.3.2",
    "postcss": "^8.5.6",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.19",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "dependencies": {
    "@andersseen/headless-components": "workspace:*",
    "@andersseen/icon": "workspace:*",
    "@andersseen/motion": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  }
}
