{
  "name": "@andersseen/web-components",
  "version": "0.0.6",
  "description": "Accessible, framework-agnostic web components built with Stencil",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/web-components/web-components.esm.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    },
    "./lazy": {
      "import": "./dist/web-components/web-components.esm.js",
      "require": "./dist/web-components/web-components.cjs.js"
    },
    "./components": {
      "types": "./dist/types/components.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*.js": "./dist/components/*.js",
    "./components/*": "./dist/components/*.js",
    "./components/all": "./dist/components/all.js",
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    },
    "./dist/web-components/web-components.css": "./dist/web-components/web-components.css",
    "./themes": "./themes/index.css",
    "./themes/*": "./themes/*",
    "./themes/colors": "./themes/colors/index.css",
    "./themes/styles": "./themes/styles/index.css",
    "./themes/colors/*": "./themes/colors/*",
    "./themes/styles/*": "./themes/styles/*",
    "./indigo-rose": "./themes/indigo-rose.css",
    "./slate-amber": "./themes/slate-amber.css",
    "./emerald-orange": "./themes/emerald-orange.css",
    "./violet-cyan": "./themes/violet-cyan.css",
    "./rose-teal": "./themes/rose-teal.css",
    "./default": "./themes/default.css",
    "./compact": "./themes/compact.css",
    "./playful": "./themes/playful.css",
    "./retro": "./themes/retro.css",
    "./elegant": "./themes/elegant.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Andersseen/and-web-components.git",
    "directory": "packages/web-components"
  },
  "author": "Andersseen",
  "files": [
    "dist/",
    "loader/",
    "themes/"
  ],
  "scripts": {
    "build": "stencil build && node scripts/generate-all-barrel.cjs",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec --e2e",
    "test:spec": "stencil test --spec",
    "test.watch": "stencil test --spec --e2e --watchAll",
    "lint": "eslint src",
    "generate": "stencil generate",
    "prepublishOnly": "pnpm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@stencil-community/postcss": "^2.2.0",
    "@stencil/angular-output-target": "^1.3.0",
    "@stencil/core": "^4.43.3",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/manager-api": "^8.6.14",
    "@storybook/theming": "^8.6.14",
    "@storybook/web-components": "^10.2.16",
    "@storybook/web-components-vite": "^10.2.16",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^10.1.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "lit": "^3.3.2",
    "postcss": "^8.5.6",
    "puppeteer": "^24.3.0",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.19",
    "typescript-eslint": "^8.57.1"
  },
  "license": "MIT",
  "dependencies": {
    "@andersseen/headless-components": "workspace:*",
    "@andersseen/icon": "workspace:*",
    "@andersseen/motion": "workspace:*",
    "@babel/runtime": "^7.26.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  }
}
